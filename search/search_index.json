{"config":{"lang":["en"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\u524d\u8a00","text":"<p>\u8fd9\u662f\u4e00\u4efd\u6a21\u4effcsdiy\u3001\u57fa\u4e8e\u6211\u4e2a\u4eba\u7684\u81ea\u5b66\u7ecf\u9a8c\uff0c\u9488\u5bf9\u5fae\u7535\u5b50/\u96c6\u6210\u7535\u8def\u76f8\u5173\u5b66\u79d1\u7684\u540c\u5b66\u7684\u81ea\u5b66\u6307\u5357\u3002</p> <p>\u540c\u65f6\u8fd9\u4e5f\u76f8\u5f53\u4e8e\u4e00\u4efd\u6211\u7684\u4e2a\u4eba\u603b\u7ed3\u4e0e\u53cd\u601d\uff0c\u5728\u5b66\u4e60\u7684\u540c\u65f6\u8bb0\u5f55\u4e0b\u81ea\u5df1\u7684\u8db3\u8ff9\uff0c\u65e2\u80fd\u8ba9\u81ea\u5df1\u66f4\u597d\u7684\u627e\u5230\u65b9\u5411\uff0c\u4e5f\u80fd\u5e2e\u52a9\u522b\u4eba\u6253\u7834\u90e8\u5206\u7684\u4fe1\u606f\u5dee\u3002\u54ea\u6015\u5bf9\u5927\u5bb6\u6709\u4e00\u70b9\u70b9\u7684\u5e2e\u52a9\u6216\u8005\u542f\u53d1\uff0c\u90fd\u662f\u5bf9\u6211\u6781\u5927\u7684\u9f13\u52b1\u548c\u6170\u85c9\u3002</p> <p>\u6211\u4e2a\u4eba\u8fd8\u53ea\u662f\u5927\u4e00\u5c0f\u767b\uff0c\u81ea\u5b66\u4e4b\u8def\u4ecd\u4efb\u91cd\u9053\u8fdc\uff0c\u6240\u4ee5\u8fd9\u672c\u6307\u5357\u5c06\u968f\u7740\u6211\u7684\u8fdb\u6b65\u6301\u7eed\u66f4\u65b0\uff0c\u6700\u540e\u966a\u4f34\u7740\u6211\u4e00\u8d77\u6210\u957f\u3002</p> <p>\u540c\u65f6\uff0c\u4e00\u4e2a\u4eba\u7684\u529b\u91cf\u7ec8\u7a76\u662f\u6709\u9650\u7684\uff0c\u671f\u5f85\u5927\u5bb6\u4e00\u8d77\u52a0\u5165\u5230\u8d21\u732e\u8005\u7684\u884c\u5217\u3002\u5982\u679c\u4f60\u6709\u60f3\u8865\u5145\u7684\u5185\u5bb9\uff0c\u6b22\u8fce\u63d0\u51faPull Request\uff0c\u5982\u679c\u4f60\u60f3\u6210\u4e3a\u8d21\u732e\u8005\u7684\u4e00\u5458\u6216\u8005\u6709\u5176\u4ed6\u5efa\u8bae\uff0c\u6b22\u8fce\u90ae\u4ef6 jiangyusu25@m.fudan.edu.cn \u6216\u8005\u5728 issue \u91cc\u63d0\u95ee</p>"},{"location":"#-csdiywiki","title":"\u68a6\u5f00\u59cb\u7684\u5730\u65b9 -- csdiy.wiki","text":""}]}